{
    "version": 2,
    "framework": null,
    "buildCommand": "",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "keuangan",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://keuangan-ecru.vercel.app",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "database",
        "DB_CONNECTION": "mysql"
    }
}
